---
const pubId = import.meta.env.PUBLIC_BEEHIIV_PUBLICATION_ID;
const action = pubId
  ? `https://embeds.beehiiv.com/${pubId}/subscribe`
  : `mailto:hello@infinitxai.com?subject=Subscribe`;
const method = pubId ? 'post' : 'get';
---
<form action={action} method={method} class="flex flex-col sm:flex-row gap-2 my-8" data-beehiiv-form>
  <input
    type="email"
    name="email"
    required
    placeholder="you@company.com"
    class="flex-1 px-4 py-3 rounded bg-white/5 border border-white/10 text-white placeholder-white/40 focus:outline-none focus:border-[var(--color-mint)]"
  />
  <button
    type="submit"
    class="px-6 py-3 rounded bg-[var(--color-mint)] text-[var(--color-ink)] font-semibold hover:opacity-90 transition"
  >
    Subscribe
  </button>
</form>
{!pubId && (
  <p class="text-xs text-white/40 -mt-6 mb-6">Newsletter signup pending — falls back to email link until BEEHIIV_PUBLICATION_ID is wired.</p>
)}
