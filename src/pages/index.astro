---
import Layout from '../layouts/Layout.astro';
import BeehiivForm from '../components/BeehiivForm.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<Layout
  title="INFINITX — Autonomous companies"
  description="More money, more time, compounding returns. Building 100 autonomous businesses."
>
  <section class="py-12">
    <h1 class="text-4xl sm:text-6xl font-bold tracking-tight mb-6">
      Autonomous companies that compound.
    </h1>
    <p class="text-lg text-white/70 mb-8 lede">
      INFINITX builds AI-native businesses that run themselves — sales, marketing, operations.
      More output, less overhead. Real revenue, real autonomy.
    </p>
    <BeehiivForm />
  </section>

  <section class="py-12 border-t border-white/10">
    <h2 class="text-2xl font-bold mb-6">Latest writing</h2>
    <ul class="space-y-4">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.id.replace(/\.mdx?$/, '')}/`} class="block group">
            <h3 class="text-xl font-semibold group-hover:text-[var(--color-mint)]">{p.data.title}</h3>
            <p class="text-white/60 text-sm">{p.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
    <a href="/blog/" class="inline-block mt-6 text-sm">All posts &rarr;</a>
  </section>
</Layout>
